# Local required
# SQLAlchemy database connection string used by the API.
TALK2DOM_DB_URI=postgresql://admin:secret@localhost:5432/talk2dom
# Secret for sessions and token signing. Use a long random value.
SECRET_KEY=replace-with-a-long-random-secret
# LLM model name passed to LangChain (example for OpenAI).
TALK2DOM_MODEL_NAME=gpt-4o-mini
# LLM provider (e.g. openai, groq, google_genai).
TALK2DOM_MODEL_PROVIDER_NAME=openai
# API key for the selected LLM provider (this one is for OpenAI).
OPENAI_API_KEY=

# Local seed options
# Auto-create a demo user/project/api key on startup when true.
LOCAL_SEED_ENABLED=true
# Seeded user email.
LOCAL_SEED_EMAIL=local@talk2dom.dev
# Seeded project display name.
LOCAL_SEED_PROJECT_NAME=Local Demo Project
# Seeded project UUID (use this as project_id in local API calls).
LOCAL_SEED_PROJECT_ID=00000000-0000-0000-0000-000000000001
# Seeded API key value for Authorization: Bearer <key>.
LOCAL_SEED_API_KEY=t2d-local-api-key
